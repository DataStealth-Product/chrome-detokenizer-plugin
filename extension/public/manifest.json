{
  "manifest_version": 3,
  "name": "Chrome Detokenizer Plugin",
  "version": "0.1.0",
  "description": "Detects tokenized DOM values and replaces them with authorized cleartext values.",
  "permissions": ["scripting", "activeTab", "storage", "tabs", "downloads", "offscreen"],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["assets/content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Detokenizer",
    "default_popup": "popup.html"
  }
}
