{
  "name": "chrome-detokenizer-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:extension": "vite --config extension/vite.config.ts",
    "build:extension": "vite build --config extension/vite.config.ts && vite build --config extension/vite.content.config.ts && node extension/scripts/verify-content-bundle.mjs",
    "package:extension": "npm run build:extension",
    "dev:mock-api": "node --import tsx mock-api/src/index.ts",
    "dev:mock-api:watch": "tsx watch mock-api/src/index.ts",
    "dev:oob": "npm run build:extension && npm run dev:mock-api",
    "test:unit": "vitest run tests/unit --config vitest.config.ts",
    "test:integration": "vitest run tests/integration --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "VITE_DETOKENIZER_API_URL=http://127.0.0.1:8877/detokenize VITE_ALLOW_HTTP_DEV=true npm run build:extension && playwright test -c tests/e2e/playwright.config.ts",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/chrome": "^0.1.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "jsdom": "^22.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^6.3.6",
    "vitest": "^3.2.4"
  }
}
